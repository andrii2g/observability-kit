{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "targets": [{ "expr": "sum by (http_route) (rate(http_server_request_duration_count[5m]))", "legendFormat": "{{http_route}}", "refId": "A" }],
      "title": "Requests by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "targets": [{ "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_count[5m]))", "legendFormat": "{{http_response_status_code}}", "refId": "A" }],
      "title": "Requests by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket[5m])))", "legendFormat": "{{http_route}}", "refId": "A" }],
      "title": "Latency by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 4,
      "targets": [{ "expr": "sum(rate(http_server_request_duration_count{http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_count[5m])), 1)", "legendFormat": "5xx", "refId": "A" }],
      "title": "5xx Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 5,
      "targets": [{ "expr": "sum(rate(http_server_request_duration_count{http_response_status_code=~\"4..\"}[5m])) / clamp_min(sum(rate(http_server_request_duration_count[5m])), 1)", "legendFormat": "4xx", "refId": "A" }],
      "title": "4xx Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 6,
      "targets": [{ "expr": "topk(5, histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_bucket[5m]))))", "legendFormat": "{{http_route}}", "refId": "A" }],
      "title": "Slowest Endpoints",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["observability-kit", "http"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "HTTP API",
  "uid": "observability-kit-http-api",
  "version": 2
}
